# ACL Rehab Companion — secrets template
# Copy to .streamlit/secrets.toml and fill in real values.
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
# NEVER commit secrets.toml to version control.

# Required
ANTHROPIC_API_KEY = "sk-ant-api03-REPLACE_ME"

# SQLite path (local) or postgres URL (cloud)
DATABASE_URL = "acl_rehab.db"

# Server-side pepper for journal encryption.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# WARNING: changing this invalidates all existing journal entries.
JOURNAL_PEPPER = ""

# Optional
# CHROMA_PERSIST_DIR = "./chroma_db"
